---
import "./CardImage.css";

import type { ImageSource } from "../../types/image";

interface Props {
  image: ImageSource;

  alt: string;

  loading?: "lazy" | "eager";
}

const { image, alt, loading = "lazy" } = Astro.props;
---

<picture class="card-image">
  <source srcset={image.avif.src} type="image/avif" />

  <source srcset={image.webp.src} type="image/webp" />

  <img
    class="card-image__img"
    src={image.webp.src}
    alt={alt}
    width={image.webp.width}
    height={image.webp.height}
    loading={loading}
    decoding="async"
  />
</picture>
