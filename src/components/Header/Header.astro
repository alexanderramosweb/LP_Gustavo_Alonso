---
import Container from "../Container/Container.astro";

/*
 * Header del sitio.
 *
 * Responsabilidades:
 * - Mostrar la identidad del sitio.
 * - Contener la navegación principal.
 *
 * Nota:
 * El componente Container se encarga de limitar el ancho
 * máximo y centrar el contenido.
 */
---

<header class="header">
  <Container>
    <div class="header__content">
      <!-- ==========================================================
           Logo
           ========================================================== -->
      <a href="/" class="header__brand" aria-label="Ir a la página de inicio">
        <span class="header__logo" aria-hidden="true"></span>

        <span class="header__brand-name"> SERGIO MENDOZA </span>
      </a>

      <!-- ==========================================================
           Navegación principal
           ========================================================== -->
      <nav class="header__nav" aria-label="Navegación principal">
        <ul class="header__menu">
          <li class="header__item">
            <a
              href="https://wa.me/573000000000"
              class="header__link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Contactar por WhatsApp"
            >
              <span class="header__icon" aria-hidden="true"></span>

              <span class="header__link-text"> WhatsApp </span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </Container>
</header>
