---
import { Image } from "astro:assets";
import Container from "../Container/Container.astro";
import iconBrand from "../../assets/icons/icon_brand.svg";
import iconWhatsapp from "../../assets/icons/icon_brand-whatsapp.svg";
import "./Header.css";

/*
 * Header del sitio optimizado para IA y Accesibilidad.
 */
---

<header
  class="header"
  role="banner"
  itemscope
  itemtype="https://schema.org/WPHeader"
>
  <Container>
    <div class="header__content">
      <!-- Identidad de Marca con Microdatos (Schema) -->
      <div
        itemscope
        itemtype="https://schema.org/Person"
        class="header__identity"
      >
        <a
          href="/"
          class="header__brand"
          rel="home"
          itemprop="url"
          aria-label="Ir a la página de inicio de Sergio Mendoza"
        >
          <Image
            src={iconBrand}
            alt="Logotipo de Sergio Mendoza"
            class="header__icon-img"
            width={16}
            height={16}
            loading="eager"
          />
          <span class="header__brand-name" itemprop="name">SERGIO MENDOZA</span>
        </a>
      </div>

      <!-- Navegación y Canales de Contacto Directo -->
      <nav
        class="header__nav"
        aria-label="Navegación principal del sitio"
        itemscope
        itemtype="https://schema.org/SiteNavigationElement"
      >
        <ul class="header__menu">
          <li class="header__item">
            <a
              href="https://wa.me/573000000000"
              class="header__link"
              target="_blank"
              rel="noopener noreferrer"
              itemprop="sameAs"
              aria-label="Contactar a Sergio Mendoza por WhatsApp (abre en una nueva ventana)"
            >
              <Image
                src={iconWhatsapp}
                alt=""
                class="header__icon-img"
                width={24}
                height={24}
                aria-hidden="true"
              />
              <span class="header__link-text">whatsapp</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </Container>
</header>
