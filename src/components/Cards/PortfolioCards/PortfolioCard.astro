---
// src/components/portfolioCards/PortfolioCard.astro
interface Props {
  image: string;
  title: string;
  category: string;
  year: string;
}

const { image, title, category, year } = Astro.props;
---

<article class="project-card">
  <div class="project-card__image-wrapper">
    <!-- Aquí es donde Astro renderizará la ruta de la imagen que le pases -->
    <img src={image} alt={title} class="project-card__image" loading="lazy" />
  </div>
  <div class="project-card__content">
    <h3 class="project-card__title">{title}</h3>
    <div class="project-card__meta">
      <span>{category}</span>
      <span class="project-card__divider">•</span>
      <span>{year}</span>
    </div>
  </div>
</article>
